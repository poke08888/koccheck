# Copy to .env (used by docker-compose) and adjust for production.

# Postgres password (compose uses it for both the db and the app's DATABASE_URL)
PG_PASSWORD=kocpass

# Secret used to sign auth tokens — MUST be a long random string in production
AUTH_SECRET=change-me-to-a-long-random-string

# Initial admin password (login: admin / <this>)
ADMIN_PASSWORD=admin123

# --- For running the server directly (not via compose) ---
# Leave DATABASE_URL unset to use the bundled SQLite file (server/data/koc.db).
# Set it to use PostgreSQL instead:
# DATABASE_URL=postgres://kocuser:kocpass@localhost:5432/koc
# PORT=4000
